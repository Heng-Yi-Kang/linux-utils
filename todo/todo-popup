#!/usr/bin/env python3

import gi
import json
import os

gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk

TODO_FILE = os.path.expanduser("~/.local/share/todo-popup.json")
os.makedirs(os.path.dirname(TODO_FILE), exist_ok=True)

def load_todos():
	if not os.path.exists(TODO_FILE):
		return {"active": [], "completed": []}
	with open(TODO_FILE, "r", encoding="utf-8") as f:
		data = json.load(f)
	if isinstance(data, list):
		return {"active": data, "completed": []}
	return {
		"active": data.get("active", []),
		"completed": data.get("completed", []),
	}

def save_todos(todos):
	with open(TODO_FILE, "w", encoding="utf-8") as f:
		json.dump(todos, f, indent=2)

class TodoApp(Gtk.Application):
	def __init__(self):
		super().__init__(application_id="com.yikang.todo.popup")
		self.todos = load_todos()

	def do_activate(self):
		window = Gtk.ApplicationWindow(application=self)
		window.set_title("Todo")
		window.set_default_size(320,420)
		window.set_resizable(False)
		window.set_decorated(False)
		
		box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
		box.set_margin_top(12)
		box.set_margin_bottom(12)
		box.set_margin_start(12)
		box.set_margin_end(12)

		entry = Gtk.Entry()
		entry.set_placeholder_text("Add new todo...")

		notebook = Gtk.Notebook()
		active_listbox = Gtk.ListBox()
		completed_listbox = Gtk.ListBox()
		notebook.append_page(active_listbox, Gtk.Label(label="Active"))
		notebook.append_page(completed_listbox, Gtk.Label(label="Completed"))

		def refresh():
			while child:= active_listbox.get_first_child():
				active_listbox.remove(child)
			while child:= completed_listbox.get_first_child():
				completed_listbox.remove(child)

			for index, todo in enumerate(self.todos["active"]):
				row_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
			
				label = Gtk.Label(label=todo)
				label.set_xalign(0)
				label.set_hexpand(True)

				row_box.append(label)

				row = Gtk.ListBoxRow()
				row.set_child(row_box)
				active_listbox.append(row)

			for index, todo in enumerate(self.todos["completed"]):
				row_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
			
				label = Gtk.Label(label=todo)
				label.set_xalign(0)
				label.set_hexpand(True)

				row_box.append(label)

				row = Gtk.ListBoxRow()
				row.set_child(row_box)
				completed_listbox.append(row)

		def add_todo(_):
			text = entry.get_text().strip()
			if text:
				self.todos["active"].append(text)
				save_todos(self.todos)
				entry.set_text("")
				refresh()
			
		entry.connect("activate", add_todo)

		def delete_selected():
			if notebook.get_current_page() == 0:
				selected_row = active_listbox.get_selected_row()
				if selected_row:
					del self.todos["active"][selected_row.get_index()]
			else:
				selected_row = completed_listbox.get_selected_row()
				if selected_row:
					del self.todos["completed"][selected_row.get_index()]
			if selected_row:
				save_todos(self.todos)
				refresh()

		def complete_selected():
			if notebook.get_current_page() != 0:
				return False
			selected_row = active_listbox.get_selected_row()
			if not selected_row:
				return False
			item = self.todos["active"].pop(selected_row.get_index())
			self.todos["completed"].append(item)
			save_todos(self.todos)
			refresh()
			return True

		def key_pressed(controller, keyval, keycode, state):
			if window.get_focus() == entry:
				return False
			if keyval in (Gdk.KEY_Delete, Gdk.KEY_BackSpace, Gdk.KEY_d):
				delete_selected()
				return True
			if keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter, Gdk.KEY_space):
				return complete_selected()
			return False

		key_controller = Gtk.EventControllerKey()
		key_controller.connect("key-pressed", key_pressed)
		window.add_controller(key_controller)
	
		box.append(entry)
		box.append(notebook)

		window.set_child(box)
		refresh()
		window.present()

	def do_shutdown(self):
		save_todos(self.todos)
		super().do_shutdown()

app = TodoApp()
app.run()
